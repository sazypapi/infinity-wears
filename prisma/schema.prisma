generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Product {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  description    String
  material       String
  seoTitle       String
  seoDescription String
  seoTags        String[]
  images      String[] 
review Review[]
  status         ProductStatus  @default(ACTIVE)
  gender         Gender  @default(UNISEX)
  quantity      Int
  collectionId   String?
  collection     Collection?    @relation(fields: [collectionId], references: [id])
  variants       ColorVariant[]
  category       Category 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cartItem CartItem[]
  sold  Int @default(0)
  hasStock Boolean @default(true)
 recentlyViewed RecentlyViewed[]
  wishlist Wishlist[]
  minEffectivePrice Float @default(0)
}

model ColorVariant {
  id          String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorName  String   
  colorHex   String   

  coverImage String

  price      Float
  discount   Float?
  inStock    Boolean  @default(true)
  cartItem CartItem[]
  sizes      String[] 
effectivePrice Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}
model Collection {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  
  collectionLinks CollectionLink[]
}
model Review {
  id        String   @id @default(uuid())
  clerkId  String
  rating Int
  description String
  authorName String
  authorImageUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId String
   product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
model Cart {
  id        String   @id @default(uuid())
  clerkId  String
  cartItems CartItem[]
  numItemsInCart Int @default(0)
  cartTotal Int @default(0)
  shipping Int @default(500)
  tax Int @default(0)
  taxRate Float @default(0.1)
  orderTotal Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  variantId String
  variant ColorVariant @relation(fields: [variantId],references: [id],onDelete: Cascade)
  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId   String
  amount  Int
  size  String
  color String
  price Float
  discount Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Order {
  id        String       @id @default(cuid())
  clerkId   String
  totalAmount Int
  reference String
  status    OrderStatus       // e.g., 'PAID', 'PENDING'
  createdAt DateTime     @default(now())
  orderItems OrderItem[]
  updatedAt DateTime @default(now()) @updatedAt
  deliveryStatus DeliveryStatus @default(PROCESSING)  // ← add this
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  size      String?
  price     Int
  imageUrl  String?
  quantity  Int
  order Order @relation(fields: [orderId],references: [id], onDelete: Cascade)
}
model Wishlist {
  id        String   @id @default(uuid())
  clerkId  String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model RecentlyViewed {
  id        String   @id @default(uuid())
  clerkId   String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([clerkId, productId]) // prevents duplicate entries per user
  @@index([clerkId])
}
model HomeCarousel{
  id String @id @default(uuid())
  image String
  text String
    mobileImage String
  link String
}
model CollectionLink {
  id           String     @id @default(uuid())
  image        String
  heading      String
  subHeading String
  collectionName String     @unique
  collection   Collection @relation(fields: [collectionName], references: [name], onDelete: Cascade)
    createdAt DateTime @default(now())
}
model UserProfile {
  id          String   @id @default(uuid())
  clerkId     String   @unique
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customOrders CustomOrder[]

  customPieceRequests CustomPieceRequest[]
}
model CustomPiece{
  id          String   @id @default(uuid())
  image        String
    mobileImage String

}
model CustomPieceRequest {
  id            String    @id @default(cuid())
  userId        String
  user          UserProfile      @relation(fields: [userId], references: [clerkId])
  garmentType   GarmentType
  description   String
  sampleImages  String[]
  phoneNumber   String
  status        CustomRequestStatus @default(PENDING)
  adminNote     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customOrder   CustomOrder?
}

model CustomOrder {
  id            String    @id @default(cuid())
  userId        String
  user          UserProfile      @relation(fields: [userId], references: [clerkId])
  requestId     String    @unique
  request       CustomPieceRequest @relation(fields: [requestId], references: [id])
  agreedPrice   Float
  status        CustomOrderStatus  @default(IN_PRODUCTION)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
model Contact{
  id String @id @default(cuid())
  email String
  phoneNumber String
  message String
  name String
  attendedTo Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum GarmentType {
  SHIRT
  TROUSER
  DRESS
  JACKET
  SWEATSHIRT
}
enum CustomRequestStatus {
  PENDING
  SEEN
  ACCEPTED
  REJECTED
  DONE
}
enum CustomOrderStatus {
  IN_PRODUCTION
  READY
  DELIVERED
}
enum ProductStatus {
  ACTIVE
  DRAFT
  INACTIVE
}
enum Gender {
  MALE
  FEMALE
  UNISEX
}
enum Category {
TSHIRTS
JEANS
DRESSES
JACKETS
ACTIVEWEAR
SWEATSHIRTS
HOODIES
SHIRTS
SHORTS
JORTS
TROUSERS
OUTERWEAR
KNITWEAR
ACCESSORIES
FOOTWEAR
LONGSLEEVES
TANKTOPS
}

enum OrderStatus {
  PENDING
  PROCESSED
  FINISHED
  PAID
  FAILED
  CANCELLED
}
enum DeliveryStatus {
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
}